{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "plugin": [
    "oh-my-openagent@latest",
    [
      "token-optimizer-opencode",
      {
        "qualityWindow": 20,
        "features": {
          "qualityNudges": true,
          "loopDetection": true,
          "smartCompaction": true,
          "continuity": true,
          "activityTracking": true,
          "trends": true
        }
      }
    ],
    [
      "opencode-ponytail",
      {
        "defaultMode": "full"
      }
    ]
  ],
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  }
}
